{
  "entities": {
    "SharedSlides": {
      "title": "Shared Slides",
      "description": "A collection of shared analysis slides.",
      "type": "object",
      "properties": {
        "slides": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "ticketId": { "type": "string" },
              "csat": { "type": "number" },
              "nps": { "type": "number" },
              "summary": { "type": "string" },
              "keyIssues": { "type": "string" },
              "finalResult": { "type": "string" },
              "sentiment": { "type": "string", "enum": ["positive", "neutral", "negative"] }
            }
          }
        },
        "batchData": {
          "type": "object",
          "properties": {
            "summary": { "type": "object" },
            "individual": { "type": "array" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["createdAt"]
    }
  },
  "firestore": {
    "/shared_slides/{id}": {
      "schema": "SharedSlides",
      "description": "Publicly accessible shared slides."
    }
  }
}
